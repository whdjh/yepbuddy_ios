    "lg": { "offset": [0, 10], "blur": 25, "color": "rgba(58,42,26,0.15)" }
  },

  "shadow-dark": {
    "sm": { "offset": [0, 1], "blur": 3, "color": "rgba(0,0,0,0.15)" },
    "md": { "offset": [0, 4], "blur": 8, "color": "rgba(0,0,0,0.20)" },
