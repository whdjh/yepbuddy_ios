{
  "$description": "yepbuddy — Layer 3: Component Tokens · Semantic을 컴포넌트별로 매핑 · Liquid Glass 대응",

  "button": {
    "primary":  { "bg": "{fill-strong}",  "color": "{on-strong}",  "height": "{size.btn-md}", "radius": "{radius-rule.button}", "font": "{typography.body-lg}" },
    "accent":   { "bg": "{accent}",       "color": "{on-accent}",  "height": "{size.btn-md}", "radius": "{radius-rule.button}", "font": "{typography.body-lg}" },
    "outline":  { "bg": "transparent",    "color": "{accent}",     "height": "{size.btn-md}", "radius": "{radius-rule.button}", "borderColor": "{accent}", "borderWidth": "{borderWidth.input}" },
    "ghost":    { "bg": "transparent",    "color": "{fg-secondary}","height": "{size.btn-sm}", "radius": "{radius-rule.segment-inner}" },
    "danger":   { "bg": "{status.error}", "color": "{white}",      "height": "{size.btn-md}", "radius": "{radius-rule.button}" },
    "padding-x": "{spacing.6}"
  },

  "icon-button": {
    "back-square": { "bg": "{surface-muted}",  "size": "{size.icon-btn}", "radius": "{radius-rule.icon-btn}" },
    "back-round":  { "bg": "{surface-muted}",  "size": "{size.icon-btn}", "radius": "{radius-rule.icon-btn-round}" },
    "adjust":      { "bg": "{fill-pale}",      "size": "{size.icon-btn}", "radius": "{radius-rule.segment-inner}", "borderColor": "{border}", "borderWidth": "{borderWidth.default}" },

    "$note-back-round": "운동 상세/프로틴 상세 등 서브 페이지에서 원형 뒤로가기 사용"
  },

  "chip": {
    "default": { "bg": "{fill-pale}",  "color": "{fg}",         "borderColor": "{border}",  "height": "{size.chip}", "radius": "{radius-rule.chip}", "font": "{typography.body-sm}" },
    "active":  { "bg": "{accent}",     "color": "{on-accent}",  "borderColor": "{accent}",  "height": "{size.chip}", "radius": "{radius-rule.chip}" }
  },

  "filter-pill": {
    "$description": "프로틴/세션 리스트 필터용 — chip보다 작음",
    "default": { "bg": "{fill-pale}", "color": "{fg-secondary}", "height": 40, "radius": "{radius-rule.chip}", "font": "{typography.body-sm}", "font-weight": "{font.weight.semibold}" },
    "active":  { "bg": "{accent}",    "color": "{on-accent}",   "height": 40, "radius": "{radius-rule.chip}" },
    "padding-x": "{spacing.5}"
  },

  "body-part-pill": {
    "$description": "운동 기록 — 운동 부위 선택 필",
    "default": { "bg": "transparent", "color": "{fg}", "borderColor": "{border}", "borderWidth": "{borderWidth.input}", "height": 40, "radius": "{radius-rule.chip}", "font": "{typography.body-sm}", "font-weight": "{font.weight.semibold}" },
    "active":  { "bg": "{fill-strong}", "color": "{on-strong}", "borderColor": "{fill-strong}" },
    "padding-x": "{spacing.5}"
  },

  "badge": {
    "low":  { "bg": "{status.success-bg}", "color": "{status.success-text}" },
    "mid":  { "bg": "{status.info-bg}",    "color": "{status.info-text}" },
    "high": { "bg": "{status.error-bg}",   "color": "{status.error-text}" },
    "height": 28,
    "radius": "{radius-rule.pill}",
    "padding-x": "{spacing.3}",
    "font": "{typography.caption}",
    "font-weight": "{font.weight.bold}",

    "$dark-overrides": {
      "low":  { "bg": "{status-dark.success-bg}", "color": "{status-dark.success-text}" },
      "mid":  { "bg": "{status-dark.info-bg}",    "color": "{status-dark.info-text}" },
      "high": { "bg": "{status-dark.error-bg}",   "color": "{status-dark.error-text}" }
    }
  },

  "card": {
    "default": { "bg": "{surface}",        "borderColor": "{border}", "borderWidth": "{borderWidth.default}", "radius": "{radius-rule.card-outer}", "padding": "{layout.card-padding}", "shadow": "sm" },
    "subtle":  { "bg": "{surface-subtle}",  "borderColor": "{border}", "radius": "{radius-rule.card-inner}", "padding": "{layout.card-inner-pad}" },
    "glass": {
      "$description": "Liquid Glass 카드 — BlurView + 반투명 배경",
      "material": "glass",
      "bg-light":         "{glass.light.bg}",
      "bg-dark":          "{glass.dark.bg}",
      "borderColor-light": "{glass.light.border}",
      "borderColor-dark":  "{glass.dark.border}",
      "borderWidth":       "{borderWidth.default}",
      "radius":            "{radius-rule.card-outer}",
      "padding":           "{layout.card-padding}",
      "blur-light":        "{glass.light.blur}",
      "blur-dark":         "{glass.dark.blur}",
      "intensity-light":   "{glass.light.intensity}",
      "intensity-dark":    "{glass.dark.intensity}"
    }
  },

  "input": {
    "default": { "bg": "{surface}",   "color": "{fg}",          "borderColor": "{border}",    "height": "{size.input}", "radius": "{radius-rule.input}", "borderWidth": "{borderWidth.input}", "padding-x": "{spacing.4}", "font": "{typography.body-md}" },
    "focus":   { "borderColor": "{accent}", "shadow": "0 0 0 3px {accent}26" },
    "error":   { "borderColor": "{status.error}" },
    "placeholder": "{fg-disabled}"
  },

  "textarea": {
    "$extends": "input.default",
    "min-height": 160,
    "padding": "{spacing.4}",
    "font": "{typography.body-md}"
  },

  "number-input": {
    "width": 72,
    "height": "{size.num-input}",
    "radius": "{radius-rule.input}",
    "font": "{typography.number-sm}",
    "empty-color": "{fg-disabled}",
    "filled-color": "{accent}",
    "editing-borderColor": "{accent}"
  },

  "icon-box": {
    "sm": { "size": "{size.icon-box-sm}", "radius": "{radius-rule.icon-box}" },
    "md": { "size": "{size.icon-box-md}", "radius": "{radius-rule.icon-box}" },
    "lg": { "size": "{size.icon-box-lg}", "radius": "{radius-rule.icon-box}" },
    "xl": { "size": 80, "radius": "{radius-rule.pill}" },
    "borderWidth": "{borderWidth.icon}",
    "borderColor": "{bg}"
  },

  "ring-progress": {
    "calendar":  { "size": "{size.ring-cal}",   "stroke": 4 },
    "dashboard": { "size": "{size.ring-dash}",  "stroke": 10 },
    "tempo":     { "size": "{size.ring-tempo}", "stroke": 14 },
    "countdown": { "size": "{size.ring-cd}",    "stroke": 16 },
    "mini":      { "size": 40,                  "stroke": 4 },
    "track-color": "{border-subtle}",
    "fill-color":  "{accent}"
  },

  "segment-toggle": {
    "bg": "{surface-muted}",
    "radius-outer": "{radius-rule.segment-outer}",
    "radius-inner": "{radius-rule.segment-inner}",
    "height": "{size.touch}",
    "padding": 4,
    "active":   { "bg": "{surface}", "color": "{fg}", "font": "{typography.body-md}", "font-weight": "{font.weight.semibold}", "shadow": "sm" },
    "inactive": { "color": "{fg-tertiary}", "font-weight": "{font.weight.semibold}" }
  },

  "stepper": {
    "$description": "템포 — 수축/이완/횟수/세트 스테퍼",
    "bg": "{surface}",
    "borderColor": "{border}",
    "borderWidth": "{borderWidth.default}",
    "radius": "{radius-rule.input}",
    "padding": "{spacing.3.5}",
    "gap": "{spacing.2}",
    "label-font": "{typography.caption}",
    "label-color": "{fg-secondary}",
    "value-font": "{typography.number-sm}",
    "value-color": "{fg}",
    "btn-size": "{size.icon-btn}",
    "btn-bg": "{surface-muted}",
    "btn-radius": "{radius-rule.icon-btn}"
  },

  "stepper-rest": {
    "$description": "템포 — 휴식 스테퍼 (와이드, ±10 점프 버튼 포함)",
    "$extends": "stepper",
    "jump-btn-size": "{size.icon-btn}",
    "jump-btn-bg": "{surface-muted}",
    "jump-btn-color": "{fg-secondary}",
    "jump-btn-font": "{typography.label}",
    "jump-btn-font-weight": "{font.weight.bold}"
  },

  "session-card": {
    "$extends": "card.default",
    "padding": "{spacing.5}",
    "icon-size": "{size.icon-box-lg}",
    "icon-radius": "{radius-rule.input}",
    "kcal-font": "{typography.number-sm}",
    "kcal-color": "{accent}",
    "part-font": "{typography.body-sm}",
    "part-font-weight": "{font.weight.semibold}",
    "part-color": "{fg-secondary}",
    "date-font": "{typography.body-sm}",
    "date-color": "{fg-secondary}",
    "gap": "{spacing.4}"
  },

  "protein-card": {
    "$extends": "card.default",
    "padding": "{spacing.5}",
    "name-font": "{typography.body-lg}",
    "name-font-weight": "{font.weight.bold}",
    "meta-label": "{typography.caption}",
    "meta-label-color": "{fg-secondary}",
    "meta-value": "{typography.body-md}",
    "meta-value-weight": "{font.weight.bold}",
    "meta-accent": "{accent}",
    "gap": "{spacing.5}"
  },

  "stat-grid": {
    "columns": 2,
    "gap": "{spacing.5}",
    "label-font": "{typography.label}",
    "label-color": "{fg-secondary}",
    "value-font": "{typography.number-xs}",
    "value-color": "{accent}"
  },

  "memo-card": {
    "$description": "운동 상세 — 메모 영역",
    "light": { "bg": "{earth.300}", "color": "rgba(250,247,242,0.5)" },
    "dark":  { "bg": "{earth.350}", "color": "rgba(255,255,255,0.35)" },
    "min-height": 200,
    "radius": "{radius-rule.card-outer}",
    "padding": "{spacing.6}",
    "font": "{typography.body-md}"
  },

  "hr-chart": {
    "$description": "운동 상세 — 심박수 차트",
    "$extends": "card.default",
    "line-color": "{accent}",
    "fill-opacity": 0.25,
    "guide-color": "{accent}",
    "guide-opacity": 0.3,
    "peak-color": "{error.500}",
    "label-font": "{typography.caption}",
    "label-color": "{fg-secondary}",
    "avg-font": "{typography.body-sm}"
  },

  "map-card": {
    "$description": "운동 상세 — 지도 플레이스홀더",
    "light": { "bg": "{cream.200}" },
    "dark":  { "bg": "{earth.350}" },
    "height": 140,
    "radius": "{radius-rule.card-outer}",
    "dot-color": "{status.success}",
    "dot-size": 12,
    "label-font": "{typography.caption}",
    "label-bg-light": "rgba(255,255,255,0.8)",
    "label-bg-dark":  "rgba(255,255,255,0.1)"
  },

  "price-chart": {
    "$description": "프로틴 상세 — 가격 추이 차트",
    "$extends": "card.default",
    "line-color": "{accent}",
    "fill-opacity": 0.25,
    "dot-color": "{accent}",
    "grid-color-light": "{cream.200}",
    "grid-color-dark": "rgba(255,255,255,0.06)",
    "label-font": "{typography.caption}",
    "label-color": "{fg-secondary}"
  },

  "pill-nav": {
    "bg": "{fill-strong}",
    "radius": "{radius-rule.pill}",
    "padding": "{spacing.1.5}",
    "gap": "{spacing.1.5}",
    "min-height": "{size.touch}",
    "tab-radius": "{radius-rule.card-outer}",
    "tab-padding-y": "{spacing.2.5}",
    "active-bg": "{accent}",
    "label-color": "{on-strong}",
    "label-active-color": "{on-accent}",
    "label-font": { "size": 11, "weight": "{font.weight.semibold}" },
    "icon-size": 20,
    "material": "glass",

    "$note": "Liquid Glass — expo-blur BlurView 위에 fill-strong 틴트 오버레이"
  },

  "home-indicator": {
    "width": 134,
    "height": 5,
    "radius": "{radius.xs}",
    "light": { "bg": "{earth.300}", "opacity": 0.15 },
    "dark":  { "bg": "{white}",     "opacity": 0.15 }
  },

  "calendar-cell": {
    "min-height": "{size.touch}",
    "gap": 4,
    "date-font": "{typography.caption}",
    "date-font-weight": "{font.weight.semibold}",
    "today-bg": "{accent}",
    "today-color-light": "{on-accent}",
    "today-color-dark":  "{on-accent}",
    "today-size": 24,
    "today-radius": "{radius.full}",
    "dot-size": 5,
    "dot-color-light": "{status.success}",
    "dot-color-dark":  "{status.success-bright}"
  },

  "countdown": {
    "bg": "{workout.bg}",
    "number-font": "{typography.number-xl}",
    "number-color-light": "{fg}",
    "number-color-dark": "{white}",
    "ring-color-light": "{accent}",
    "ring-color-dark": "{workout.accent}",
    "ring-track-light": "{cream.200}",
    "ring-track-dark": "rgba(155,126,86,0.25)",
    "label-color-light": "{fg-secondary}",
    "label-color-dark": "rgba(255,255,255,0.6)",
    "label-font": "{typography.title}",
    "icon-bg-light": "{cream.200}",
    "icon-bg-dark": "rgba(255,255,255,0.1)"
  },

  "active-workout": {
    "bg-light": "{bg}",
    "bg-dark": "{workout.bg}",
    "bpm-font": "{typography.number-lg}",
    "bpm-color-light": "{fg}",
    "bpm-color-dark": "{white}",
    "heart-color": "{workout.heart}",
    "stat-font": "{typography.number-md}",
    "stat-color-light": "{fg}",
    "stat-color-dark": "{white}",
    "stat-label-font": "{typography.body-sm}",
    "stat-label-color-light": "{fg-secondary}",
    "stat-label-color-dark": "{workout.fg-secondary}"
  },

  "bottom-drawer": {
    "bg": "{workout.surface}",
    "radius": "{radius-rule.drawer}",
    "handle-color": "rgba(255,255,255,0.2)",
    "handle-size": { "width": 40, "height": 5 },
    "timer-font": { "size": 36, "weight": "{font.weight.bold}", "leading": "{font.lineHeight.none}" },
    "timer-color": "{workout.accent}",
    "btn-bg": "rgba(255,255,255,0.08)",
    "btn-pause-bg": "rgba(255,255,255,0.12)",
    "btn-size": "{size.drawer-btn-lg}",
    "btn-radius": "{radius-rule.card-outer}",
    "mini-ring-size": 40,
    "mini-ring-stroke": 4,
    "mini-ring-track": "rgba(255,255,255,0.12)",
    "mini-ring-fill": "rgba(200,173,126,0.6)",
    "material": "glass.workout",

    "$extended-state": {
      "end-btn":  { "bg": "rgba(255,107,90,0.15)", "color": "{status.error-bright}", "height": "{size.drawer-btn}", "radius": "{radius-rule.button}" },
      "safe-btn": { "bg": "rgba(255,255,255,0.08)", "color": "{white}", "height": "{size.drawer-btn}", "radius": "{radius-rule.button}" },
      "lock-btn": { "bg": "rgba(255,255,255,0.08)", "color": "rgba(255,255,255,0.5)", "height": "{size.drawer-btn}", "radius": "{radius-rule.button}" }
    },

    "offset-y-collapsed": -20,
    "$note": "Liquid Glass 하단 시트 — expo-blur 또는 expo-glass-effect 사용"
  }
}
