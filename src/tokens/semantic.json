{
  "$description": "yepbuddy — Layer 2: Semantic Tokens · Primitive를 용도별로 매핑 · Light/Dark · Liquid Glass",

  "light": {
    "bg":              "{cream.50}",
    "surface":         "{white}",
    "surface-subtle":  "{cream.100}",
    "surface-muted":   "{cream.200}",
    "fill-pale":       "{sand.50}",
    "fill-strong":     "{earth.300}",

    "fg":              "{earth.300}",
    "fg-secondary":    "{khaki.400}",
    "fg-tertiary":     "{olive.300}",
    "fg-disabled":     "{neutral.400}",

    "accent":          "{khaki.300}",
    "accent-hover":    "{khaki.400}",

    "border":          "{cream.400}",
    "border-subtle":   "{cream.300}",
    "border-strong":   "{sand.400}",

    "on-accent":       "{cream.50}",
    "on-strong":       "{cream.50}",

    "$note-fg-secondary": "기존 #5A4A36 → khaki.400(#876B45)로 변경. 실제 화면과 일치"
  },

  "dark": {
    "bg":              "{earth.450}",
    "surface":         "{earth.350}",
    "surface-subtle":  "{earth.250}",
    "surface-muted":   "{earth.200}",
    "fill-pale":       "{olive.400}",
    "fill-strong":     "{cream.200}",

    "fg":              "{white}",
    "fg-secondary":    "{cream.200}",
    "fg-tertiary":     "{cream.400}",
    "fg-disabled":     "{olive.200}",

    "accent":          "{sand.100}",
    "accent-hover":    "{sand.300}",

    "border":          "{olive.400}",
    "border-subtle":   "{earth.200}",
    "border-strong":   "{olive.200}",

    "on-accent":       "{earth.450}",
    "on-strong":       "{earth.450}",

    "$note-bg":      "#1C1C1E (earth.450) — 실제 다크 화면 배경",
    "$note-surface": "#2C2C2E (earth.350) — 다크 카드 배경",
    "$note-accent":  "#D4883A (sand.100) — 다크 오렌지 액센트"
  },

  "$workout-override": {
    "$description": "운동 중 화면은 dark 테마 기반 + CSS 변수 override (global.css .workout-mode 참조)",
    "bg":           "{earth.400}  → #231E17",
    "surface":      "rgba(60,55,45,0.92)",
    "fg-secondary": "rgba(255,255,255,0.45)",
    "accent":       "{sand.300}  → #C4A87E",
    "heart":        "{sand.300}  → #C4A87E"
  },

  "status-light": {
    "$description": "라이트모드 status — OKLCH L 균일화 적용",
    "success-bg":      "{success.50}",
    "success-text":    "{success.700}",
    "success":         "{success.500}",
    "success-bright":  "{success.400}",
    "info-bg":         "{info.50}",
    "info-text":       "{info.700}",
    "info-bright":     "{info.400}",
    "error-bg":        "{error.50}",
    "error-text":      "{error.700}",
    "error":           "{error.500}",
    "error-bright":    "{error.600}"
  },

  "status-dark": {
    "$description": "다크모드 status — APCA 기반 명도대비 강화 (alpha 0.15→0.18)",
    "success-bg":      "rgba(67,194,81,0.18)",
    "success-text":    "{success.400}",
    "success":         "{success.400}",
    "success-bright":  "{success.400}",
    "info-bg":         "rgba(96,170,243,0.18)",
    "info-text":       "{info.400}",
    "info-bright":     "{info.400}",
    "error-bg":        "rgba(232,88,84,0.18)",
    "error-text":      "{error.600}",
    "error":           "{error.600}",
    "error-bright":    "{error.600}"
  },

  "typography": {
    "display":    { "size": "{font.size.6xl}",  "weight": "{font.weight.bold}",     "leading": "{font.lineHeight.snug}",   "tracking": "{font.letterSpacing.tight}" },
    "heading-lg": { "size": "{font.size.4xl}",  "weight": "{font.weight.bold}",     "leading": "{font.lineHeight.snug}" },
    "heading-md": { "size": "{font.size.3xl}",  "weight": "{font.weight.bold}",     "leading": "{font.lineHeight.snug}" },
    "heading-sm": { "size": "{font.size.2xl}",  "weight": "{font.weight.bold}",     "leading": "{font.lineHeight.snug}" },
    "title":      { "size": "{font.size.xl}",   "weight": "{font.weight.bold}",     "leading": "{font.lineHeight.snug}" },
    "body-lg":    { "size": "{font.size.lg}",   "weight": "{font.weight.semibold}", "leading": "{font.lineHeight.normal}" },
    "body-md":    { "size": "{font.size.md}",   "weight": "{font.weight.regular}",  "leading": "{font.lineHeight.relaxed}" },
    "body-sm":    { "size": "{font.size.base}",  "weight": "{font.weight.medium}",  "leading": "{font.lineHeight.normal}" },
    "label":      { "size": "{font.size.sm}",   "weight": "{font.weight.semibold}", "leading": "{font.lineHeight.tight}" },
    "caption":    { "size": "{font.size.xs}",   "weight": "{font.weight.medium}",   "leading": "{font.lineHeight.snug}" },
    "number-xl":  { "size": "{font.size.10xl}", "weight": "{font.weight.bold}",     "leading": "{font.lineHeight.none}" },
    "number-lg":  { "size": "{font.size.9xl}",  "weight": "{font.weight.bold}",     "leading": "{font.lineHeight.none}" },
    "number-md":  { "size": "{font.size.7xl}",  "weight": "{font.weight.bold}",     "leading": "{font.lineHeight.none}" },
    "number-sm":  { "size": "{font.size.4xl}",  "weight": "{font.weight.bold}",     "leading": "{font.lineHeight.none}" },
    "number-xs":  { "size": "{font.size.3xl}",  "weight": "{font.weight.bold}",     "leading": "{font.lineHeight.none}" },

    "$note-number-lg": "기존 8xl(40) → 9xl(72)로 변경. 운동 중 심박수 실제 사이즈 반영"
  },

  "layout": {
    "screen-px":      "{spacing.5}",
    "card-padding":   "{spacing.6}",
    "card-inner-pad": "{spacing.4}",
    "section-gap":    "{spacing.6}",
    "grid-gap":       "{spacing.4}",
    "component-gap":  "{spacing.3}",
    "chip-gap":       "{spacing.2.5}"
  },

  "radius-rule": {
    "$description": "outer = inner × 2 원칙",
    "card-outer":    "{radius.xl}",
    "card-inner":    "{radius.sm}",
    "button":        "{radius.lg}",
    "input":         "{radius.lg}",
    "icon-btn":      "{radius.icon}",
    "icon-btn-round": "{radius.full}",
    "icon-box":      "{radius.sm}",
    "segment-outer": "{radius.icon}",
    "segment-inner": "{radius.md}",
    "chip":          "{radius.chip}",
    "drawer":        "{radius.drawer}",
    "pill":          "{radius.full}",

    "$note-icon-btn-round": "상세 페이지 뒤로가기 버튼은 원형(full radius)"
  },

  "glass": {
    "$description": "Liquid Glass 머티리얼 — expo-blur BlurView 또는 expo-glass-effect GlassView 사용",

    "light": {
      "tint": "light",
      "bg":        "rgba(255,255,255,0.65)",
      "bg-thin":   "rgba(255,255,255,0.35)",
      "border":    "rgba(255,255,255,0.5)",
      "highlight": "rgba(255,255,255,0.8)",
      "blur":      "{glass.blur.md}",
      "intensity": "{glass.intensity.regular}"
    },

    "dark": {
      "tint": "dark",
      "bg":        "rgba(255,255,255,0.12)",
      "bg-thin":   "rgba(255,255,255,0.06)",
      "border":    "rgba(255,255,255,0.18)",
      "highlight": "rgba(255,255,255,0.25)",
      "blur":      "{glass.blur.md}",
      "intensity": "{glass.intensity.regular}"
    },

    "workout": {
      "tint": "dark",
      "bg":        "rgba(60,55,45,0.75)",
      "border":    "rgba(255,255,255,0.1)",
      "blur":      "{glass.blur.lg}",
      "intensity": "{glass.intensity.strong}"
    },

    "$note-implementation": "RN: expo-blur(BlurView intensity/tint) 또는 expo-glass-effect(GlassView). Web: backdrop-filter: blur() saturate()"
  }
}
